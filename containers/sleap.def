Bootstrap: docker
# Ubuntu 24.04 -> Python 3.12. Modern SLEAP (1.5+/1.6+) requires Python
# >=3.11,<3.14, so the 22.04 base (Python 3.10) cannot install sleap[nn].
#
# CUDA 13 base: SLEAP 1.6.3's sleap-nn pulls a CUDA 13 torch build (the
# nvidia-*-cu13 wheels), so the base tag is matched to CUDA 13.0 (torch's cu13
# wheels target the 13.0 toolkit). torch bundles its own CUDA runtime via those
# wheels; the base mainly supplies cuDNN and userspace libs, and --nv injects
# the host driver at run time. Keep this tag, the pip --index-url below, and the
# torch CUDA build in lockstep -- bump all three together.
From: nvidia/cuda:13.0.3-cudnn-runtime-ubuntu24.04

# =============================================================================
# Apptainer definition for modern SLEAP (PyTorch / sleap-nn backend).
#
# Build with scripts/build_sleap_sif.sh (which passes SLEAP_VERSION). Manually:
#   apptainer build sleap_1.6.3.sif containers/sleap.def
#   # or pin a version:
#   apptainer build --build-arg SLEAP_VERSION=1.6.3 sleap_1.6.3.sif containers/sleap.def
#
# NOTE: SLEAP's install story shifts across 1.6.x. If a build fails, check the
# pinned version's install docs and adjust the pip line in %post:
#   - https://docs.sleap.ai/  (installation)
#   - https://nn.sleap.ai/    (sleap-nn / PyTorch backend, --torch-backend)
# The CUDA base tag above should match the CUDA build of the torch that
# sleap-nn pulls in (currently cu13). Bump both together if needed.
# =============================================================================

%arguments
    SLEAP_VERSION=1.6.3

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # System deps: Python, video I/O (ffmpeg/OpenCV runtime), git.
    apt-get update
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        ffmpeg libgl1 libglib2.0-0 \
        git ca-certificates curl
    rm -rf /var/lib/apt/lists/*

    # Install into a venv (not system Python). Ubuntu 24.04 marks the system
    # interpreter externally-managed (PEP 668), so system-wide pip is blocked;
    # a venv sidesteps that and the "pip as root" warning.
    python3 -m venv /opt/venv
    /opt/venv/bin/pip install --no-cache-dir --upgrade pip

    # Install a pinned SLEAP with the PyTorch (sleap-nn) backend.
    # The CUDA torch wheels come from PyTorch's cu130 index (matches the CUDA 13
    # base above). --no-cache-dir keeps pip from buffering the multi-GB wheel set
    # to disk/RAM twice; combined with a disk-backed TMPDIR (set by the build
    # script) this avoids the OOM kill that hits when /tmp is RAM-backed (tmpfs).
    /opt/venv/bin/pip install --no-cache-dir \
        --extra-index-url https://download.pytorch.org/whl/cu130 \
        "sleap[nn]=={{ SLEAP_VERSION }}"

    # Smoke-check the CLIs exist at build time (no GPU needed here).
    /opt/venv/bin/sleap-nn --help >/dev/null 2>&1 || echo "WARN: 'sleap-nn' CLI not found; check version/extras"

%environment
    export PATH=/opt/venv/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    # Avoid each task fighting over all cores for CPU math.
    export OMP_NUM_THREADS=${OMP_NUM_THREADS:-1}

%labels
    Maintainer kylethieringer@gmail.com
    Description SLEAP (PyTorch/sleap-nn) inference for Hyak
    SLEAP_Version {{ SLEAP_VERSION }}

%help
    Apptainer image for running modern SLEAP (sleap-nn) inference on Hyak.
    Run with GPU passthrough using --nv, e.g.:
        apptainer exec --nv sleap_1.6.3.sif sleap-nn track -i video.mp4 -m model/ -o out.slp
    Verify GPU access:
        apptainer exec --nv sleap_1.6.3.sif python3 -c "import torch; print(torch.cuda.is_available())"
